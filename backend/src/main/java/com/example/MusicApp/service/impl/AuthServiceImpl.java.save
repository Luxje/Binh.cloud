package com.example.MusicApp.service.impl;

import com.example.MusicApp.dto.request.LoginRequestDTO;
import com.example.MusicApp.model.Account;
import com.example.MusicApp.repository.AccountRepository;
import com.example.MusicApp.service.AuthService;
import lombok.RequiredArgsConstructor;
import org.springframework.stereotype.Service;



@Service
@RequiredArgsConstructor
public class AuthServiceImpl implements AuthService {

    private final AccountRepository accountRepository;

    public boolean login(LoginRequestDTO loginRequestDTO) {
        Account currentAccount = accountRepository.findByEmail(loginRequestDTO.getUserEmail());
        if (currentAccount != null) {
            return currentAccount.getPassword().equals(loginRequestDTO.getUserPassword());
        }
        return false;
    }

	 public TokenResponseDTO getToken() {
	

}



}
